# ─────────────────────────────────────────────────────────────────────────────
# Web Application Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT session tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_generate_a_random_secret_key_here

# Admin credentials for the web UI
WEB_USERNAME=admin
WEB_PASSWORD=changeme

# Session timeout options (minutes): 15, 60, 1440 (1 day), 10080 (1 week)
SESSION_TIMEOUT_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth Credentials
# Create these at: https://console.cloud.google.com/
#   - Create a project → Enable "Photos Library API"
#   - OAuth 2.0 → Create credentials → Web application
#   - Add authorized redirect URI: http://YOUR_HOST:8080/api/google/callback
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/google/callback

# ─────────────────────────────────────────────────────────────────────────────
# Storage Settings
# ─────────────────────────────────────────────────────────────────────────────
# Absolute path where photos will be saved (inside the container or host)
DESTINATION_PATH=/data/photos

# Internal path for the app database
DATABASE_PATH=/data/gpd.db

# Path for app logs
LOG_PATH=/data/logs

# ─────────────────────────────────────────────────────────────────────────────
# Sync Settings
# ─────────────────────────────────────────────────────────────────────────────
# Download speed limit in MB/s (0 = unlimited)
SPEED_LIMIT_MBPS=0

# How often to check for new photos (minutes)
SYNC_INTERVAL_MINUTES=60

# Max retries for failed downloads
MAX_RETRIES=3

# Chunk size for downloads in bytes (65536 = 64KB)
CHUNK_SIZE=65536

# ─────────────────────────────────────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
DEBUG=false
